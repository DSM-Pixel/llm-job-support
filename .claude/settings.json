{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(uvx:*)",
      "Bash(pip:*)",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(ruff format:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)",
      "Bash(gradio:*)",
      "Bash(streamlit run:*)",
      "Bash(uvicorn:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "PowerShell(uv:*)",
      "PowerShell(uvx:*)",
      "PowerShell(python:*)",
      "PowerShell(pytest:*)",
      "PowerShell(ruff:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(New-Item:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:data.go.kr)",
      "WebFetch(domain:www.data.go.kr)",
      "WebFetch(domain:gradio.app)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:python.langchain.com)",
      "WebFetch(domain:docs.llamaindex.ai)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "PowerShell(Remove-Item -Recurse -Force C:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)"
    ]
  },
  "env": {
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/format_py.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start.py"
          }
        ]
      }
    ]
  }
}
